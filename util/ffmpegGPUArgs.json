{
    "nvidia-nvenc-auto": {
        "name": "Nvidia / NVENC (auto)",
        "platform": ["win32", "linux"],
        "arch": ["ia32", "x64"],
        "string": "nvenc",
        "pre": ["-hwaccel", "cuda", "-hwaccel_output_format", "cuda"],
        "post": ["-c:v", "h264_nvenc"],
        "vf": {
            "scale": "scale_cuda",
            "hwupload": "hwupload_cuda"
        }
    },
    "nvidia-nvenc-buffered": {
        "name": "Nvidia / NVENC (buffered)",
        "description": "This includes the \"extra hw frames\" FFmpeg option, which is required for some GPUs. Use this if auto doesn't work.",
        "platform": ["win32", "linux"],
        "arch": ["ia32", "x64"],
        "string": "nvenc",
        "pre": ["-hwaccel", "cuda", "-hwaccel_output_format", "cuda", "-extra_hw_frames", "10"],
        "post": ["-c:v", "h264_nvenc"],
        "vf": {
            "scale": "scale_cuda",
            "hwupload": "hwupload_cuda"
        }
    },
    "intel-qsv": {
        "name": "Intel / Quick Sync Video",
        "platform": ["win32", "linux"],
        "arch": ["ia32", "x64"],
        "string": "qsv",
        "pre": ["-hwaccel", "auto"],
        "post": ["-c:v", "h264_qsv"],
        "vf": {
            "scale": "scale_qsv"
        }
    },
    "amd-amf": {
        "name": "AMD / Advanced Media Framework",
        "description": "AMD's encoders are generally much worse in quality [(benchmarks @ tomshardware.com)](https://www.tomshardware.com/news/amd-intel-nvidia-video-encoding-performance-quality-tested) than Nvidia's or Intel's. If you have a beefy enough CPU, you should disable all hardware acceleration instead.",
        "platform": ["win32", "linux"],
        "arch": ["ia32", "x64"],
        "string": "amf",
        "pre": ["-hwaccel", "auto"],
        "post": ["-c:v", "h264_amf"]
    },
    "windows-mf": {
        "name": "Windows Media Foundation",
        "description": "Windows Media Foundation provides a general interface for every device with hardware acceleration. Useful for devices that has no specialized support in FFmpeg (such as Qualcomm Snapdragon).",
        "platform": ["win32"],
        "string": "mf",
        "pre": ["-hwaccel", "d3d12va"],
        "post": ["-c:v", "h264_mf", "-hw_encoding", "1"],
        "vf": {
            "scale": "scale_npp"
        }
    },
    "mesa-vaapi": {
        "name": "Mesa / VAAPI",
        "platform": ["linux"],
        "string": "vaapi",
        "pre": ["-hwaccel", "vaapi", "-hwaccel_output_format", "vaapi"],
        "post": ["-c:v", "h264_vaapi"],
        "vf": {
            "scale": "scale_vaapi"
        }
    },
    "apple-videotoolbox": {
        "name": "Apple / VideoToolbox",
        "platform": ["darwin"],
        "string": "videotoolbox",
        "pre": ["-hwaccel", "auto"],
        "post": ["-c:v", "h264_videotoolbox"]
    }
}
